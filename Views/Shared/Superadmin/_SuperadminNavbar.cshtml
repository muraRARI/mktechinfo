<!-- ================= MOBILE MENU ================= -->
<div id="overlay" class="hidden fixed inset-0 bg-black/60 z-40"></div>

<div id="nav-menu"
     class="fixed top-0 left-0 h-full w-72 bg-slate-950
     transform -translate-x-full transition-transform duration-500 z-50 shadow-2xl">

    <div class="flex items-center justify-between p-6 border-b border-slate-800">
        <span class="text-xl font-bold text-white">Super Admin</span>

        <button id="close-menu" class="text-white text-2xl">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>

    <ul class="flex flex-col gap-3 p-6 text-slate-200 font-semibold">

        <li>
            <a asp-area="Superadmin" asp-controller="Dashboard" asp-action="Index"
               class="block py-2 hover:text-white">Dashboard</a>
        </li>

        <li>
            <a asp-area="Superadmin" asp-controller="User" asp-action="Index"
               class="block py-2 hover:text-white">Users</a>
        </li>

        <li>
            <a asp-area="Superadmin" asp-controller="Role" asp-action="Index"
               class="block py-2 hover:text-white">Roles</a>
        </li>

        <li>
            <a asp-area="Superadmin" asp-controller="Product" asp-action="Index"
               class="block py-2 hover:text-white">Products</a>
        </li>


        <li class="relative group">
            <a href="#" class="hover:text-white flex items-center gap-1 py-2">
                Blog
                <i class="bi bi-chevron-down text-sm"></i>
            </a>

            <!-- IMPORTANT: add pt-2 wrapper -->
            <div class="absolute left-0 top-full pt-2 hidden group-hover:block z-50">
                <ul class="bg-white text-black rounded-lg shadow-lg w-48">

                    <li>
                        <a asp-area="Superadmin" asp-controller="Blog" asp-action="List"
                           class="block px-4 py-2 hover:bg-gray-100">
                            All Blogs
                        </a>
                    </li>

                    <li>
                        <a asp-area="Superadmin" asp-controller="Blog" asp-action="Create"
                           class="block px-4 py-2 hover:bg-gray-100">
                            Create Blog
                        </a>
                    </li>

                    <li>
                        <a asp-area="Superadmin" asp-controller="BlogCategory" asp-action="Create"
                           class="block px-4 py-2 hover:bg-gray-100">
                            Blog Categories
                        </a>
                    </li>

                </ul>
            </div>
        </li>
    </ul>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const menuToggle = document.getElementById("menu-toggle");
        const closeMenu = document.getElementById("close-menu");
        const navMenu = document.getElementById("nav-menu");
        const overlay = document.getElementById("overlay");

        function openMenu() {
            navMenu.classList.remove("-translate-x-full");
            overlay.classList.remove("hidden");
            document.body.style.overflow = "hidden";
        }

        function closeMenuFunc() {
            navMenu.classList.add("-translate-x-full");
            overlay.classList.add("hidden");
            document.body.style.overflow = "auto";
        }

        if (menuToggle) menuToggle.addEventListener("click", openMenu);
        if (closeMenu) closeMenu.addEventListener("click", closeMenuFunc);
        if (overlay) overlay.addEventListener("click", closeMenuFunc);

    });
</script>