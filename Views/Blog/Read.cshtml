@model mkinfotech.DTOs.Blog.BlogDto

@{
    ViewData["Title"] = Model?.Title ?? "Blog Post";

    // Safely calculate initials for the user avatar bubble
    string initials = "A";
    if (Model != null && !string.IsNullOrWhiteSpace(Model.AuthorName))
    {
        var parts = Model.AuthorName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length > 0)
        {
            initials = parts.Length > 1
                ? $"{parts[0][0]}{parts[parts.Length - 1][0]}".ToUpper()
                : parts[0][0].ToString().ToUpper();
        }
    }
}

<div class="max-w-4xl mx-auto px-4 py-10 sm:px-6 lg:px-8">

    <!-- Category Tag -->
    <div class="mb-4">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-700 tracking-wide uppercase shadow-sm">
            📁 @(Model?.CategoryName ?? "General")
        </span>
    </div>

    <!-- Blog Title -->
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-gray-900 tracking-tight mb-6 leading-tight">
        @(Model?.Title ?? "Untitled Post")
    </h1>

    <!-- Author & Meta Section -->
    <div class="flex items-center space-x-4 pb-8 mb-8 border-b border-gray-100">
        <div class="flex-shrink-0">
            <!-- Dynamic Avatar Bubble with gradient fallback -->
            <div class="h-11 w-11 rounded-full bg-gradient-to-tr from-indigo-500 to-purple-600 flex items-center justify-center text-white font-bold text-sm shadow-sm ring-2 ring-white">
                @initials
            </div>
        </div>
        <div class="flex-1 min-w-0">
            <p class="text-sm font-semibold text-gray-900 truncate">
                By @(Model?.AuthorName ?? "Anonymous")
            </p>
            <p class="text-xs text-gray-500">
                Published on @(Model?.CreatedAt.ToString("dd MMM yyyy") ?? DateTime.Now.ToString("dd MMM yyyy"))
            </p>
        </div>
    </div>

    <!-- Featured Image -->
    @if (Model != null && !string.IsNullOrEmpty(Model.ImageUrl))
    {
        <div class="mb-10 overflow-hidden rounded-2xl shadow-md border border-gray-100 bg-gray-50">
            <img src="@Model.ImageUrl" alt="@Model.Title" class="w-full h-auto max-h-[480px] object-cover hover:scale-[1.01] transition-transform duration-300 ease-in-out" />
        </div>
    }

    <!-- Main Content Body -->
    <article class="prose prose-indigo prose-lg max-w-none text-gray-800 leading-relaxed tracking-normal mix-blend-normal mb-12">
        @if (Model != null && !string.IsNullOrEmpty(Model.Content))
        {
            @Html.Raw(Model.Content)
        }
        else
        {
            <p class="text-gray-400 italic">This blog post has no content to display.</p>
        }
    </article>

    <!-- Enhanced Interaction Bar (Likes, Views & Share) -->
    <div class="flex flex-wrap items-center justify-between gap-4 border-t border-b border-gray-100 py-4 mb-10 bg-gray-50/50 px-4 rounded-xl">
        <div class="flex items-center space-x-6">
            <!-- Like Button -->
          
            <!-- Views Display -->
            <div class="flex items-center space-x-1.5 text-gray-500 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
                <span class="font-medium">@(Model?.ViewsCount ?? 0) views</span>
            </div>
        </div>

     
    </div>

</div>

<!-- Interactive Interactions Script -->
<script>
    document.getElementById('shareBtn').addEventListener('click', function() {
        navigator.clipboard.writeText(window.location.href).then(() => {
            const btnSpan = this.querySelector('span');
            const originalText = btnSpan.textContent;

            btnSpan.textContent = 'Copied!';
            this.classList.add('bg-green-50', 'border-green-300', 'text-green-700');

            setTimeout(() => {
                btnSpan.textContent = originalText;
                this.classList.remove('bg-green-50', 'border-green-300', 'text-green-700');
            }, 2000);
        });
    });

    document.getElementById('likeBtn').addEventListener('click', function() {
        const svg = this.querySelector('svg');
        svg.setAttribute('fill', svg.getAttribute('fill') === 'none' ? 'currentColor' : 'none');
        this.classList.toggle('text-red-500');
        this.classList.toggle('text-gray-600');
    });
</script>