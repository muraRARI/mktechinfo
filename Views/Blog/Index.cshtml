

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MK InfoTech Blog</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Smooth transitions for interactive micro-moments */
        .card-transition {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .like-heart {
            transition: transform 0.2s ease;
        }

            .like-heart.bump {
                transform: scale(1.4);
            }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 antialiased min-h-screen flex flex-col">

    <!-- HEADER / NAVIGATION -->
    <header class="bg-white/80 backdrop-blur-md border-b border-slate-200 sticky top-0 z-50">
        <div class="max-w-6xl mx-auto p-4 flex flex-col md:flex-row md:items-center md:justify-between gap-4">

            <!-- Branding -->
            <div class="flex justify-between items-center">
                <h1 class="text-2xl font-black tracking-tight text-blue-600 hover:text-blue-700 transition cursor-pointer select-none" onclick="resetFilters()">
                    MK InfoTech<span class="text-slate-400 font-light">.Blog</span>
                </h1>
            </div>

            <!-- FILTERS SUITE -->
            <div class="flex flex-col sm:flex-row gap-3 flex-1 max-w-2xl md:justify-end">
                <!-- Advanced Search Box -->
                <div class="relative flex-1">
                    <input id="searchInput"
                           type="text"
                           placeholder="Search articles by title or keyword..."
                           class="w-full border border-slate-200 rounded-xl px-4 py-2.5 pl-10 bg-slate-50 focus:bg-white focus:ring-4 focus:ring-blue-100 focus:border-blue-500 transition outline-none text-sm">
                    <span class="absolute left-3.5 top-3.5 text-slate-400 text-xs">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                        </svg>
                    </span>
                </div>

                <!-- Custom Styled Dropdown Category -->
                <div class="relative min-w-[180px]">
                    <select id="categoryDropdown"
                            onchange="handleCategory(this)"
                            class="w-full border border-slate-200 rounded-xl px-4 py-2.5 bg-slate-50 focus:bg-white focus:ring-4 focus:ring-blue-100 focus:border-blue-500 transition outline-none text-sm appearance-none cursor-pointer font-medium text-slate-600">
                        <option value="">All Categories</option>
                    </select>
                    <span class="absolute right-3.5 top-4 pointer-events-none text-slate-400">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                        </svg>
                    </span>
                </div>
            </div>

        </div>
    </header>

    <!-- MAIN BODY CONTROLLER -->
    <main class="max-w-6xl mx-auto p-4 flex-1 w-full my-6">

        <!-- Active Filter Indicator Bar -->
        <div id="filterStatus" class="hidden items-center justify-between mb-6 bg-blue-50 border border-blue-100 rounded-xl p-3.5 text-sm text-blue-800">
            <span id="statusText">Showing filtered results</span>
            <button onclick="resetFilters()" class="font-semibold underline hover:text-blue-900 transition text-xs tracking-wide uppercase">Clear Filters</button>
        </div>

        <!-- MAIN BLOG GRID -->
        <div id="blogGrid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6"></div>

        <!-- PAGINATION SYSTEM -->
        <div class="mt-12 flex flex-col sm:flex-row items-center justify-between border-t border-slate-200 pt-6 gap-4">
            <div class="text-sm text-slate-500 font-medium" id="paginationInfo">
                Showing entries
            </div>
            <div class="inline-flex gap-2">
                <button id="prevBtn" onclick="changePage(-1)" class="px-4 py-2 bg-white border border-slate-200 text-slate-700 font-medium rounded-xl text-sm hover:bg-slate-50 disabled:opacity-40 disabled:hover:bg-white disabled:cursor-not-allowed transition flex items-center gap-1">
                    ← Previous
                </button>
                <button id="nextBtn" onclick="changePage(1)" class="px-4 py-2 bg-white border border-slate-200 text-slate-700 font-medium rounded-xl text-sm hover:bg-slate-50 disabled:opacity-40 disabled:hover:bg-white disabled:cursor-not-allowed transition flex items-center gap-1">
                    Next →
                </button>
            </div>
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="bg-white border-t border-slate-200 mt-12 py-6 text-center text-xs text-slate-400 font-medium">
        &copy; 2026 MK InfoTech. All rights reserved.
    </footer>

    <!-- LOGIC APPLICATION SCRIPT -->
    <script>
        // const API = "/api/BlogPublic";


        const API = "https://staging.infotech.mktechworld.co.in/api/BlogPublic";

        let page = 1;
        const pageSize = 6;
        let search = "";
        let category = "";
        let searchTimeout = null;
        let totalItems = 0;

        document.addEventListener("DOMContentLoaded", () => {
            loadCategories();
            loadBlogs();

            // Smart Input Debouncing System (Waits 350ms before triggering API request)
            document.getElementById("searchInput").addEventListener("input", (e) => {
                search = e.target.value;
                page = 1;

                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => {
                    loadBlogs();
                }, 350);
            });
        });

        // Generate dynamic modern skeleton UI shells while fetching data
        function renderSkeletons() {
            const grid = document.getElementById("blogGrid");
            let skeletonHtml = '';

            for(let i = 0; i < pageSize; i++) {
                skeletonHtml += `
                    <div class="bg-white rounded-2xl border border-slate-100 overflow-hidden shadow-sm animate-pulse">
                        <div class="h-48 bg-slate-200 w-full"></div>
                        <div class="p-5 space-y-4">
                            <div class="h-4 bg-slate-200 rounded w-1/4"></div>
                            <div class="space-y-2">
                                <div class="h-5 bg-slate-200 rounded w-full"></div>
                                <div class="h-5 bg-slate-200 rounded w-5/6"></div>
                            </div>
                            <div class="space-y-1.5 pt-2">
                                <div class="h-3 bg-slate-100 rounded w-full"></div>
                                <div class="h-3 bg-slate-100 rounded w-full"></div>
                                <div class="h-3 bg-slate-100 rounded w-2/3"></div>
                            </div>
                            <div class="flex justify-between items-center pt-4 border-t border-slate-50">
                                <div class="h-8 bg-slate-200 rounded-lg w-16"></div>
                                <div class="h-6 bg-slate-200 rounded-md w-12"></div>
                            </div>
                        </div>
                    </div>
                `;
            }
            grid.innerHTML = skeletonHtml;
        }

        async function loadCategories() {
            try {
                const res = await fetch(`${API}/categories`);
                const data = await res.json();
                const dropdown = document.getElementById("categoryDropdown");

                if (data && data.data) {
                    dropdown.innerHTML = `<option value="">All Categories</option>` +
                        data.data.map(c => `<option value="${c.category_id}">${c.category_name}</option>`).join('');
                }
            } catch (err) {
                console.error("Failed to load categories", err);
            }
        }

        function handleCategory(el) {
            category = el.value;
            page = 1;
            loadBlogs();
        }

        async function loadBlogs() {
            renderSkeletons();
            updateFilterStatusView();

            let url = `${API}/published/list?page=${page}&pageSize=${pageSize}`;


            if (search) url += `&search=${encodeURIComponent(search)}`;
            if (category) url += `&categoryId=${category}`;

            try {
                const res = await fetch(url);
                const data = await res.json();
                const grid = document.getElementById("blogGrid");

                if (!data.success || !data.data || data.data.length === 0) {
                    renderEmptyState(data.success);
                    updatePaginationUI(0);
                    return;
                }

                // Dynamically track totals assuming backend provides totalCount, fallback to calculations
                totalItems = data.totalCount || (data.data.length < pageSize && page === 1 ? data.data.length : page * pageSize + 1);

                grid.innerHTML = data.data.map(post => `
                    <article class="group bg-white rounded-2xl border border-slate-200/80 shadow-sm hover:shadow-xl card-transition overflow-hidden flex flex-col">

                        <!-- Image Container with Zoom effect -->
                        <div class="h-48 w-full overflow-hidden bg-slate-100 relative">
                            <img src="${post.imageUrl || 'https://images.unsplash.com/photo-1488590528505-98d2b5aba04b?q=80&w=600&auto=format&fit=crop'}"
                                 alt="${post.title}"
                                 loading="lazy"
                                 class="h-full w-full object-cover group-hover:scale-105 card-transition"
                                 onerror="this.src='https://images.unsplash.com/photo-1488590528505-98d2b5aba04b?q=80&w=600&auto=format&fit=crop'">
                        </div>

                        <!-- Info Content Block -->
                        <div class="p-5 flex flex-col flex-1 justify-between">
                            <div>
                                <span class="inline-flex items-center text-xs font-semibold bg-blue-50 text-blue-600 px-2.5 py-1 rounded-md tracking-wide uppercase">
                                    ${post.categoryName || 'General'}
                                </span>

                                <h2 class="font-bold text-lg text-slate-900 mt-3 line-clamp-2 group-hover:text-blue-600 card-transition" title="${post.title}">
                                    ${post.title}
                                </h2>

                                <p class="text-sm text-slate-500 mt-2 line-clamp-3 leading-relaxed">
                                    ${post.shortDescription || 'No description provided for this post.'}
                                </p>
                            </div>

                            <!-- Buttons Interface Grid -->
                            <div class="flex justify-between items-center mt-6 pt-4 border-t border-slate-100">
                                <a href="/blog/${post.slug}"
                                   class="bg-blue-600 hover:bg-blue-700 text-white font-medium px-4 py-1.5 rounded-xl text-sm shadow-sm hover:shadow-md transition flex items-center gap-1">
                                    Read Article
                                </a>

                                <button onclick="likePost(this, ${post.id})"
                                        class="text-sm flex items-center gap-1.5 text-slate-500 hover:text-red-500 font-medium bg-slate-50 hover:bg-red-50 px-3 py-1.5 rounded-xl transition group/btn">
                                    <span class="like-heart text-base group-hover/btn:scale-110">❤️</span>
                                    <span id="like-${post.id}" class="text-slate-600">${post.likesCount || 0}</span>
                                </button>
                            </div>
                        </div>
                    </article>
                `).join('');

                updatePaginationUI(data.data.length);

            } catch (err) {
                console.error(err);
                renderEmptyState(false);
                updatePaginationUI(0);
            }
        }

        // Beautiful Empty State / Failure layout handler
        function renderEmptyState(isSuccessState) {
            const grid = document.getElementById("blogGrid");
            const title = isSuccessState ? "No Articles Found" : "Connection Failed";
            const message = isSuccessState
                ? "We couldn't find matches for your selection. Try altering your filters or key phrase definitions."
                : "Unable to sync information blocks from service infrastructure right now.";

            grid.innerHTML = `
                <div class="col-span-full py-16 flex flex-col items-center text-center max-w-md mx-auto">
                    <div class="w-16 h-16 bg-slate-100 rounded-2xl flex items-center justify-center text-2xl shadow-inner mb-4">
                        ${isSuccessState ? '🔎' : '⚠️'}
                    </div>
                    <h3 class="text-lg font-bold text-slate-800">${title}</h3>
                    <p class="text-sm text-slate-500 mt-1 leading-relaxed">${message}</p>
                    ${isSuccessState ? `<button onclick="resetFilters()" class="mt-4 px-4 py-2 text-xs font-semibold tracking-wide uppercase bg-blue-600 text-white rounded-xl shadow hover:bg-blue-700 transition">Reset Search Metrics</button>` : ''}
                </div>
            `;
        }

        // Micro-Interaction Animation Logic for Like Engine
        async function likePost(btnElement, id) {
            const targetSpan = document.getElementById(`like-${id}`);
            const heartNode = btnElement.querySelector('.like-heart');
            let currentCount = parseInt(targetSpan.innerText);

            // Optimistic UI updating immediately for user responsiveness
            targetSpan.innerText = currentCount + 1;
            heartNode.classList.add('bump');
            btnElement.classList.replace('text-slate-500', 'text-red-500');
            btnElement.classList.replace('bg-slate-50', 'bg-red-50');

            setTimeout(() => heartNode.classList.remove('bump'), 200);

            try {
                const res = await fetch(`${API}/like/${id}`, { method: "POST" });
                const data = await res.json();
                if (data && data.success) {
                    targetSpan.innerText = data.likesCount;
                }
            } catch (err) {
                console.error("Like tracking sync issue:", err);
            }
        }

        // Active filter status management panel
        function updateFilterStatusView() {
            const panel = document.getElementById("filterStatus");
            const txt = document.getElementById("statusText");

            if (search || category) {
                panel.classList.replace('hidden', 'flex');
                let criteria = [];
                if (search) criteria.push(`"${search}"`);
                if (category) criteria.push(`Category Specified`);
                txt.innerText = `Filtering assets by: ${criteria.join(' & ')}`;
            } else {
                panel.classList.replace('flex', 'hidden');
            }
        }

        // Contextual pagination control engine
        function updatePaginationUI(currentCount) {
            const prev = document.getElementById("prevBtn");
            const next = document.getElementById("nextBtn");
            const info = document.getElementById("paginationInfo");

            prev.disabled = page === 1;
            // Disable "Next" if returned elements match less than page sizes
            next.disabled = currentCount < pageSize;

            const startIdx = (page - 1) * pageSize + 1;
            const endIdx = startIdx + currentCount - 1;

            if (currentCount === 0) {
                info.innerText = `No items matching current parameters`;
            } else {
                info.innerText = `Displaying records ${startIdx} to ${endIdx}`;
            }
        }

        function changePage(direction) {
            page += direction;
            loadBlogs();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function resetFilters() {
            search = "";
            category = "";
            page = 1;
            document.getElementById("searchInput").value = "";
            document.getElementById("categoryDropdown").value = "";
            loadBlogs();
        }
    </script>
</body>
</html>

