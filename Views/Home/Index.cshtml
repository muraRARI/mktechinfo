<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    @{
        ViewData["Title"] = "Home Page";
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
   
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Plus Jakarta Sans', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <title>Infotech MKTechWorld | Home</title>
    <style>
        body.menu-open {
            overflow: hidden;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 antialiased selection:bg-blue-500 selection:text-white">

   
    <header id="home" class="bg-white py-16 sm:py-24 overflow-hidden relative">
        <div class="absolute inset-0 bg-[radial-gradient(#e2e8f0_1px,transparent_1px)] [background-size:16px_16px] opacity-50"></div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center relative z-10">

            <div class="text-center lg:text-left order-2 lg:order-1">
                <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-blue-50 text-blue-700 text-sm font-bold rounded-full mb-6">
                    <span class="flex h-2 w-2 rounded-full bg-blue-600 animate-ping"></span>
                    Next-Gen Web Design & Systems
                </span>
                <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6 tracking-tight text-slate-900">
                    We Build Powerful <br>Digital <span class="text-blue-600">Experiences.</span>
                </h1>
                <p class="text-base sm:text-lg text-slate-500 mb-8 max-w-xl mx-auto lg:mx-0 leading-relaxed">
                    Transforming complex business paradigms into clean, modular applications. Specializing in high-performance Next.js dashboards, custom ERP integrations, and corporate portals.
                </p>
                
            </div>

            <div class="relative order-1 lg:order-2 px-4">
                <div class="w-full h-64 sm:h-80 lg:h-[420px] bg-gradient-to-tr from-slate-900 via-blue-950 to-blue-900 rounded-3xl shadow-2xl flex items-center justify-center overflow-hidden border border-slate-800">
                    <div class="absolute inset-0 opacity-10 bg-[linear-gradient(to_right,#808080_1px,transparent_1px),linear-gradient(to_bottom,#808080_1px,transparent_1px)] bg-[size:24px_24px]"></div>
                    <code class="text-blue-400 text-xs sm:text-sm font-mono p-6 leading-relaxed select-none block">
                        <span class="text-pink-500">const</span> mkTechWorld = {<br>
                        &nbsp;&nbsp;expertise: <span class="text-yellow-400">["Next.js", "React", "ASP.NET"]</span>,<br>
                        &nbsp;&nbsp;architecture: <span class="text-emerald-400">"Clean MVC / API Driven"</span>,<br>
                        &nbsp;&nbsp;performance: <span class="text-emerald-400">"99% Lighthouse Score"</span>,<br>
                        &nbsp;&nbsp;readyToBuild: <span class="text-pink-500">true</span><br>
                        };
                    </code>
                </div>
            </div>
        </div>
    </header>

    <!-- ================= NEW FEATURE: METRICS BAR ================= -->
    <section class="bg-blue-950 text-white py-12 relative z-20 shadow-xl border-y border-blue-900">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">
                <div>
                    <p class="text-3xl sm:text-4xl font-black text-blue-400">50+</p>
                    <p class="text-xs sm:text-sm text-blue-200/70 font-semibold uppercase tracking-wider mt-1">Projects Delivered</p>
                </div>
                <div>
                    <p class="text-3xl sm:text-4xl font-black text-blue-400">99.2%</p>
                    <p class="text-xs sm:text-sm text-blue-200/70 font-semibold uppercase tracking-wider mt-1">Client Satisfaction</p>
                </div>
                <div>
                    <p class="text-3xl sm:text-4xl font-black text-blue-400">24/7</p>
                    <p class="text-xs sm:text-sm text-blue-200/70 font-semibold uppercase tracking-wider mt-1">Deployment Support</p>
                </div>
                <div>
                    <p class="text-3xl sm:text-4xl font-black text-blue-400">100%</p>
                    <p class="text-xs sm:text-sm text-blue-200/70 font-semibold uppercase tracking-wider mt-1">Secure Architecture</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ================= SERVICES SECTION ================= -->
    <section id="services" class="py-20 sm:py-24 bg-slate-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

            <!-- Section Header -->
            <div class="mb-16 text-center lg:text-left">
                <h2 class="text-3xl font-extrabold mb-4 text-slate-900">Our Services & Solutions</h2>
                <div class="h-1.5 w-20 bg-blue-600 rounded-full mx-auto lg:mx-0"></div>
            </div>

            <!-- Services Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

                <!-- Service Card 1: Custom Web Engineering -->
                <div class="bg-white p-8 rounded-2xl border border-slate-100 hover:border-blue-500 hover:shadow-xl transition duration-300 group flex flex-col justify-between">
                    <div>
                        <!-- Icon / Image Container -->
                        <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center text-2xl mb-6 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300 overflow-hidden">
                            <!-- Swap with <img src="web-dev-icon.png" alt="Web Dev"> if preferred -->
                            <i class="bi bi-code-slash flex"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-3 text-slate-800">Custom Web Engineering</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">Dynamic web applications crafted cleanly with modern frameworks like Next.js, React ecosystem, and lightning-fast edge servers.</p>
                    </div>
                </div>

                <!-- Service Card 2: Enterprise ERP Systems -->
                <div class="bg-white p-8 rounded-2xl border border-slate-100 hover:border-blue-500 hover:shadow-xl transition duration-300 group flex flex-col justify-between">
                    <div>
                        <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center text-2xl mb-6 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300 overflow-hidden">
                            <i class="bi bi-layers flex"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-3 text-slate-800">Enterprise ERP Systems</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">Centralized applications to streamline your business functions, from complex data matrix systems to inventory monitoring.</p>
                    </div>
                </div>

                <!-- Service Card 3: Backend & API Design -->
               

                <!-- Service Card 4: E-Commerce Architecture (New!) -->
                <div class="bg-white p-8 rounded-2xl border border-slate-100 hover:border-blue-500 hover:shadow-xl transition duration-300 group flex flex-col justify-between">
                    <div>
                        <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center text-2xl mb-6 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300 overflow-hidden">
                            <i class="bi bi-cart3 flex"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-3 text-slate-800">E-Commerce Solutions</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">High-converting digital storefronts built with Shopify, WooCommerce, or fully custom headless commerce setups featuring secure payment gateways.</p>
                    </div>
                </div>

                <!-- Service Card 5: Cloud & DevOps Infrastructure (New!) -->
               

                <!-- Service Card 6: Native & Cross-Platform Mobile Apps (New!) -->
                

            </div>
        </div>
    </section>
 
</body>
</html>