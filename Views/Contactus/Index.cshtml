
@{
    ViewData["Title"] = "Contact Us | Infotech MKTechWorld";
}



<style>
    .font-inter {
        font-family: 'Inter', sans-serif;
    }

    .header-gradient {
        background: linear-gradient(-45deg, #4338ca, #6366f1, #3730a3, #4f46e5);
        background-size: 400% 400%;
        animation: gradient-flow 15s ease infinite;
    }

    @@keyframes gradient-flow {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }

    .input-focus {
        transition: all 0.3s ease;
    }

        .input-focus:focus {
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
        }
</style>

<div class="min-h-screen bg-slate-50 font-inter text-slate-900 pb-12">

    <header class="relative header-gradient py-24 px-6 overflow-hidden text-center">
        <div class="relative z-10 container mx-auto">
            <span class="inline-block px-4 py-1.5 mb-6 text-xs font-bold tracking-widest text-indigo-100 uppercase bg-white/10 backdrop-blur-md rounded-full border border-white/20">
                Get In Touch
            </span>
            <h1 class="text-5xl md:text-6xl font-black text-white mb-6 tracking-tight">
                Let's Build the <span class="text-indigo-200">Future.</span>
            </h1>
            <p class="text-xl text-indigo-50/90 max-w-2xl mx-auto font-normal">
                Have a project in mind? Reach out to <strong>Infotech MKTechWorld</strong> and let’s turn your vision into high-performance software.
            </p>
        </div>
        <div class="absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none">
            <div class="absolute -top-24 -left-24 w-96 h-96 bg-white rounded-full blur-3xl"></div>
            <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-indigo-400 rounded-full blur-3xl"></div>
        </div>
    </header>

    <section class="container mx-auto px-6 -mt-16 relative z-20">
        <div class="max-w-6xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

                <div class="lg:col-span-1 space-y-6">
                    <div class="bg-indigo-700 p-8 rounded-3xl text-white shadow-2xl h-full flex flex-col justify-between">
                        <div>
                            <h3 class="text-2xl font-bold mb-8">Contact Information</h3>

                            <div class="space-y-8">
                                <div class="flex items-start space-x-4">
                                    <div class="bg-indigo-600 p-3 rounded-xl">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                                    </div>
                                    <div>
                                        <p class="text-indigo-200 text-sm">Email us at</p>
                                        <p class="font-semibold">support@mktechworld.co.in</p>
                                    </div>
                                </div>

                                <div class="flex items-start space-x-4">
                                    <div class="bg-indigo-600 p-3 rounded-xl">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                    </div>
                                    <div>
                                        <p class="text-indigo-200 text-sm">Our Presence</p>
                                        <p class="font-semibold">Remote & Global Solutions</p>
                                    </div>
                                </div>

                                <div class="flex items-start space-x-4">
                                    <div class="bg-indigo-600 p-3 rounded-xl">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                    </div>
                                    <div>
                                        <p class="text-indigo-200 text-sm">Working Hours</p>
                                        <p class="font-semibold">Mon - Sat: 9AM - 7PM</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                       
                    </div>
                </div>

                <div class="lg:col-span-2 bg-white rounded-3xl p-8 md:p-12 shadow-xl border border-slate-100">
                    <form action="#" method="POST" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-2">Full Name</label>
                                <input type="text" placeholder="John Doe" required
                                       class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all outline-none input-focus">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-2">Email Address</label>
                                <input type="email" placeholder="john@company.com" required
                                       class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all outline-none input-focus">
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-2">Subject</label>
                            <input type="text" placeholder="How can we help?"
                                   class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all outline-none input-focus">
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-2">Your Message</label>
                            <textarea rows="5" placeholder="Tell us about your project goals..." required
                                      class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all outline-none input-focus"></textarea>
                        </div>

                        <button type="submit" class="w-full py-5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-2xl shadow-lg shadow-indigo-200 transition-all transform hover:-translate-y-1 active:scale-95">
                            Send Message to Infotech MKTechWorld
                        </button>

                        <p class="text-center text-slate-400 text-xs">
                            By clicking send, you agree to our <a href="#" class="underline hover:text-indigo-500">privacy policy</a> and <a href="#" class="underline hover:text-indigo-500">terms of service</a>.
                        </p>
                    </form>
                </div>

            </div>
        </div>
    </section>
</div>