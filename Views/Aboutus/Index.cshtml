@{
    ViewData["Title"] = "About Us | Infotech MKTechWorld";
}

<!-- Google Fonts & Font Awesome (Make sure these are in your Layout, or keep them here) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="bg-slate-50 text-slate-900 font-inter selection:bg-indigo-500 selection:text-white overflow-x-hidden">

    <!-- HERO SECTION WITH ANIMATED GRADIENT BACKGROUND -->
    <section class="relative bg-gradient-to-br from-indigo-900 via-indigo-700 to-purple-800 text-white py-32 text-center px-6 overflow-hidden">
        <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#fff_1px,transparent_1px)] [background-size:16px_16px]"></div>
        <div class="absolute -top-40 -right-40 w-80 h-80 bg-purple-500 rounded-full blur-3xl opacity-30 tracking-wide animate-pulse"></div>
        <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-indigo-500 rounded-full blur-3xl opacity-30 tracking-wide"></div>

        <div class="relative max-w-4xl mx-auto z-10 space-y-6">
            <span class="inline-block bg-indigo-500/30 text-indigo-200 text-xs font-bold tracking-widest uppercase px-4 py-1.5 rounded-full backdrop-blur-sm border border-indigo-400/20">
                Who We Are
            </span>
            <h1 class="text-5xl md:text-6xl font-black tracking-tight leading-none bg-clip-text text-transparent bg-gradient-to-r from-white via-indigo-100 to-purple-200">
                About Infotech MKTechWorld
            </h1>
            <p class="max-w-2xl mx-auto text-lg md:text-xl text-indigo-100/90 font-light leading-relaxed">
                We build scalable, secure, and high-performance web applications engineered to accelerate digital growth for forward-thinking enterprises.
            </p>
        </div>
    </section>

    <!-- STATS / TRUST BAR -->
    <section class="relative z-20 -mt-10 max-w-5xl mx-auto px-6">
        <div class="bg-white/80 backdrop-blur-md grid grid-cols-2 md:grid-cols-4 gap-6 p-8 rounded-2xl shadow-xl border border-slate-100 text-center">
            <div>
                <p class="text-3xl md:text-4xl font-extrabold text-indigo-600">99.9%</p>
                <p class="text-sm font-medium text-slate-500 mt-1">Uptime Guaranteed</p>
            </div>
            <div class="border-l border-slate-100">
                <p class="text-3xl md:text-4xl font-extrabold text-purple-600">50+</p>
                <p class="text-sm font-medium text-slate-500 mt-1">Projects Delivered</p>
            </div>
            <div class="border-l border-slate-100">
                <p class="text-3xl md:text-4xl font-extrabold text-pink-600">100%</p>
                <p class="text-sm font-medium text-slate-500 mt-1">Secure Systems</p>
            </div>
            <div class="border-l border-slate-100">
                <p class="text-3xl md:text-4xl font-extrabold text-indigo-600">24/7</p>
                <p class="text-sm font-medium text-slate-500 mt-1">Expert Support</p>
            </div>
        </div>
    </section>

    <!-- MISSION & VISION (INTERACTIVE HOVER CARDS) -->
    <section class="container mx-auto px-6 py-24 grid md:grid-cols-2 gap-12 max-w-6xl">

        <!-- Mission Card -->
        <div class="group relative bg-white p-10 rounded-3xl shadow-sm hover:shadow-2xl border border-slate-100 transition-all duration-300 hover:-translate-y-2 overflow-hidden">
            <div class="absolute top-0 left-0 w-2 h-full bg-indigo-600 transition-all duration-300 group-hover:w-3"></div>
            <div class="w-14 h-14 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center mb-6 text-2xl group-hover:bg-indigo-600 group-hover:text-white transition-all duration-300">
                <i class="fa-solid fa-bullseye"></i>
            </div>
            <h2 class="text-3xl font-bold text-slate-800 mb-4 tracking-tight">Our Mission</h2>
            <p class="text-slate-600 leading-relaxed text-lg">
                To deliver high-quality, tailor-made software solutions that solve complex real-world problems and drive seamless digital transformation for businesses worldwide.
            </p>
        </div>

        <!-- Vision Card -->
        <div class="group relative bg-white p-10 rounded-3xl shadow-sm hover:shadow-2xl border border-slate-100 transition-all duration-300 hover:-translate-y-2 overflow-hidden">
            <div class="absolute top-0 left-0 w-2 h-full bg-purple-600 transition-all duration-300 group-hover:w-3"></div>
            <div class="w-14 h-14 bg-purple-50 text-purple-600 rounded-2xl flex items-center justify-center mb-6 text-2xl group-hover:bg-purple-600 group-hover:text-white transition-all duration-300">
                <i class="fa-solid fa-eye"></i>
            </div>
            <h2 class="text-3xl font-bold text-slate-800 mb-4 tracking-tight">Our Vision</h2>
            <p class="text-slate-600 leading-relaxed text-lg">
                To become a globally trusted, frontier technology partner recognized inherently for architectural innovation, peak product performance, and unyielding reliability.
            </p>
        </div>

    </section>

    <!-- CORE VALUES -->
    <section class="bg-slate-100/70 border-y border-slate-200/50 py-24 px-6 relative">
        <div class="container mx-auto text-center mb-16 max-w-3xl">
            <span class="text-indigo-600 font-bold tracking-wider text-xs uppercase bg-indigo-50 px-3 py-1 rounded-md">Foundations</span>
            <h2 class="text-4xl font-black text-slate-900 mt-3">Our Core Values</h2>
            <p class="text-slate-500 mt-2">The engineering principles that guide every line of code we write.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 container mx-auto max-w-6xl">

            <!-- Value 1 -->
            <div class="group bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl border border-slate-200/60 transition-all duration-300">
                <div class="w-12 h-12 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center text-xl mb-6 group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-bolt"></i>
                </div>
                <h3 class="text-xl font-bold text-slate-800 mb-3 group-hover:text-indigo-600 transition-colors">Performance</h3>
                <p class="text-slate-600 text-sm leading-relaxed">We build ultra-fast, lightweight, and deeply optimized systems engineered to scale effortlessly under high loads.</p>
            </div>

            <!-- Value 2 -->
            <div class="group bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl border border-slate-200/60 transition-all duration-300">
                <div class="w-12 h-12 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center text-xl mb-6 group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-shield-halved"></i>
                </div>
                <h3 class="text-xl font-bold text-slate-800 mb-3 group-hover:text-purple-600 transition-colors">Security</h3>
                <p class="text-slate-600 text-sm leading-relaxed">We enforce enterprise-grade security protocols, robust encryption models, and compliant protection schemes default into every app.</p>
            </div>

            <!-- Value 3 -->
            <div class="group bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl border border-slate-200/60 transition-all duration-300">
                <div class="w-12 h-12 rounded-xl bg-pink-50 text-pink-600 flex items-center justify-center text-xl mb-6 group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-lightbulb"></i>
                </div>
                <h3 class="text-xl font-bold text-slate-800 mb-3 group-hover:text-pink-600 transition-colors">Innovation</h3>
                <p class="text-slate-600 text-sm leading-relaxed">We actively map modern stacks, cloud-native strategies, and modern design frameworks to construct resilient, future-proof ecosystems.</p>
            </div>

        </div>
    </section>

    <!-- LEADERSHIP (INTERACTIVE MODAL CARD/HOVER EFFECT) -->
    <section class="container mx-auto px-6 py-24 text-center max-w-5xl">
        <div class="mb-16">
            <span class="text-purple-600 font-bold tracking-wider text-xs uppercase bg-purple-50 px-3 py-1 rounded-md">The Minds Behind</span>
            <h2 class="text-4xl font-black text-slate-900 mt-3">Our Leadership</h2>
        </div>

        <div class="flex justify-center">
            <div class="group relative bg-white p-10 rounded-3xl shadow-lg hover:shadow-2xl border border-slate-100 max-w-md transition-all duration-300 transform hover:-translate-y-1">
                <!-- Decorative Ring Interaction -->
                <div class="relative w-36 h-36 mx-auto mb-6">
                    <div class="absolute inset-0 rounded-full border-2 border-dashed border-indigo-400 group-hover:rotate-180 transition-transform duration-1000 ease-out"></div>
                    <img src="/team/murari.png"
                         class="w-32 h-32 absolute inset-2 mx-auto rounded-full object-cover border-4 border-white shadow-md"
                         alt="Founder of Infotech MKTechWorld" />
                </div>

                <h3 class="text-2xl font-bold text-slate-800 tracking-tight">Founder</h3>
                <p class="text-indigo-600 font-semibold text-sm tracking-wide uppercase mt-1">Infotech MKTechWorld</p>

                <div class="w-12 h-1 bg-indigo-100 mx-auto my-4 rounded transition-all duration-300 group-hover:w-24 group-hover:bg-indigo-500"></div>

                <p class="text-slate-600 text-base leading-relaxed">
                    A passionate full-stack developer dedicated to crafting scalable end-to-end web architectures, seamless database integrations, and high-performance digital solutions.
                </p>

                <!-- Social Action links inside the interactive card -->
               @*  <div class="flex justify-center gap-4 mt-6 text-slate-400">
                    <a href="#" class="hover:text-indigo-600 transition-colors text-lg"><i class="fa-brands fa-linkedin"></i></a>
                    <a href="#" class="hover:text-slate-900 transition-colors text-lg"><i class="fa-brands fa-github"></i></a>
                    <a href="#" class="hover:text-indigo-400 transition-colors text-lg"><i class="fa-brands fa-twitter"></i></a>
                </div> *@
            </div>
        </div>
    </section>
    <!-- IMMERSIVE CALL TO ACTION -->
    <section class="relative bg-gradient-to-r from-indigo-700 to-purple-800 text-white py-24 text-center px-6 overflow-hidden">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff08_1px,transparent_1px),linear-gradient(to_bottom,#ffffff08_1px,transparent_1px)] bg-[size:32px_32px]"></div>

        <div class="relative max-w-3xl mx-auto z-10 space-y-8">
            <h2 class="text-4xl md:text-5xl font-black tracking-tight">
                Ready to build something phenomenal?
            </h2>
            <p class="text-indigo-100 text-lg max-w-xl mx-auto font-light">
                Let’s collaborate to turn your concepts into a high-converting, performance-driven digital asset.
            </p>

            <div class="pt-4">

              
                <a asp-controller="Contactus" asp-action="Index"
                   class="group inline-flex items-center gap-3 bg-white text-indigo-700 font-bold px-10 py-4 rounded-xl shadow-lg shadow-indigo-900/20 hover:bg-slate-50 transition-all hover:scale-105 transform duration-200">
                    Contact Us
                    <i class="fa-solid fa-arrow-right transition-transform group-hover:translate-x-1"></i>
                </a>
            </div>
        </div>
    </section>

</div>