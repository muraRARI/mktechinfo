@{
    // Layout = "~/Views/Shared/_Layout.cshtml";

    
    Layout = "~/Views/Shared/Superadmin/_SuperadminLayout.cshtml";

    ViewBag.Title = "Super Admin Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Super Admin Dashboard</title>

    <!-- Tailwind (optional if already included in layout) -->
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #f4f6fb;
        }

        .card {
            transition: all 0.3s ease;
        }

            .card:hover {
                transform: translateY(-5px);
            }
    </style>
</head>

<body>

    <div class="p-6">

        <!-- Header -->
        <div class="mb-6">
            <h1 class="text-3xl font-bold text-gray-800">Super Admin Dashboard</h1>
            <p class="text-gray-500">Manage users, roles, system settings and analytics</p>
        </div>

        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">

            <div class="card bg-white p-5 rounded-2xl shadow">
                <h2 class="text-gray-500">Total Users</h2>
                <p class="text-3xl font-bold text-blue-600">1,245</p>
            </div>

            <div class="card bg-white p-5 rounded-2xl shadow">
                <h2 class="text-gray-500">Active Users</h2>
                <p class="text-3xl font-bold text-green-600">980</p>
            </div>

            <div class="card bg-white p-5 rounded-2xl shadow">
                <h2 class="text-gray-500">Admins</h2>
                <p class="text-3xl font-bold text-purple-600">12</p>
            </div>

            <div class="card bg-white p-5 rounded-2xl shadow">
                <h2 class="text-gray-500">New Signups</h2>
                <p class="text-3xl font-bold text-orange-600">34</p>
            </div>

        </div>

        <!-- Quick Actions -->
        <div class="mt-8 bg-white p-6 rounded-2xl shadow">
            <h2 class="text-xl font-semibold mb-4">Quick Actions</h2>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

                <a href="/SuperAdmin/Users"
                   class="p-4 bg-blue-50 rounded-xl hover:bg-blue-100">
                    👤 Manage Users
                </a>

                <a href="/SuperAdmin/Roles"
                   class="p-4 bg-green-50 rounded-xl hover:bg-green-100">
                    🛡️ Manage Roles
                </a>

                <a href="/SuperAdmin/Settings"
                   class="p-4 bg-purple-50 rounded-xl hover:bg-purple-100">
                    ⚙️ System Settings
                </a>

            </div>
        </div>

        <!-- Recent Activity -->
        <div class="mt-8 bg-white p-6 rounded-2xl shadow">
            <h2 class="text-xl font-semibold mb-4">Recent Activity</h2>

            <ul class="space-y-3 text-gray-600">
                <li>✔ New user "Amit" registered</li>
                <li>✔ Role updated for "Rahul"</li>
                <li>✔ Admin "Murari" logged in</li>
                <li>✔ System settings updated</li>
            </ul>
        </div>

    </div>

</body>
</html>