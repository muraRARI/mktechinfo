@{
    // Layout = null;
    Layout = "~/Views/Shared/Superadmin/_SuperadminLayout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Responsive Admin Blog Dashboard</title>

  
    <style>
        /* Hidden layout overrides to sync DataTables with Tailwind */
        .dataTables_wrapper .dataTables_filter,
        .dataTables_wrapper .dataTables_length {
            display: none !important;
        }

        table.dataTable {
            border-collapse: collapse !important;
            border-bottom: 1px solid #e5e7eb !important;
            width: 100% !important;
        }

            table.dataTable thead th {
                border-bottom: 2px solid #e5e7eb !important;
                background-color: #f9fafb;
                color: #374151;
                font-weight: 600;
                text-transform: uppercase;
                font-size: 0.75rem;
                letter-spacing: 0.05em;
                padding: 14px 16px !important;
                white-space: nowrap;
            }

            table.dataTable tbody td {
                padding: 14px 16px !important;
                border-bottom: 1px solid #f3f4f6 !important;
                color: #4b5563;
                font-size: 0.875rem;
                vertical-align: middle;
                white-space: nowrap; /* Prevents awkward column squeezing */
            }

        /* Modern Pagination styling blocks */
        .dataTables_wrapper .dataTables_paginate {
            padding-top: 1rem !important;
            display: flex;
            gap: 0.25rem;
            justify-content: flex-end;
            flex-wrap: wrap;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button {
                border: 1px solid #e5e7eb !important;
                background: #ffffff !important;
                color: #374151 !important;
                border-radius: 0.375rem !important;
                padding: 0.4rem 0.8rem !important;
                font-size: 0.875rem !important;
            }

                .dataTables_wrapper .dataTables_paginate .paginate_button.current,
                .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
                    background: #2563eb !important;
                    color: white !important;
                    border-color: #2563eb !important;
                }

                .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
                    background: #f3f4f6 !important;
                    color: #111827 !important;
                    border-color: #d1d5db !important;
                }

        .dataTables_wrapper .dataTables_info {
            padding-top: 1.2rem !important;
            font-size: 0.875rem !important;
            color: #6b7280 !important;
        }
    </style>
</head>

<body class="bg-gray-50 min-h-screen font-sans antialiased p-4 md:p-6">

    <div class="max-w-7xl mx-auto">

        <!-- HEADER -->
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-6">
            <div>
                <h1 class="text-xl md:text-2xl font-bold text-gray-900 tracking-tight">Blog Management</h1>
                <p class="text-sm text-gray-500">Create, monitor, and update your published or layout items.</p>
            </div>

            <button onclick="handleAction('create', 0)"
                    class="inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white px-4 py-2.5 rounded-lg font-medium text-sm transition-colors shadow-sm gap-2 w-full sm:w-auto">
                <i class="fa-solid fa-plus text-xs"></i> Create New Post
            </button>
        </div>

        <!-- FILTERS BAR -->
        <div class="flex flex-col md:flex-row gap-3 mb-6 bg-white p-4 rounded-xl border border-gray-200 shadow-sm">
            <div class="relative flex-1">
                <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
                <input id="searchBox"
                       class="border border-gray-300 pl-9 pr-4 py-2 rounded-lg w-full text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all"
                       placeholder="Search title, slugs, or keywords..." />
            </div>

            <div class="w-full md:w-48">
                <select id="statusFilter" class="w-full border border-gray-300 p-2 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all">
                    <option value="">All Statuses</option>
                    <option value="PUBLISHED">Published</option>
                    <option value="DRAFT">Draft</option>
                </select>
            </div>

            <button onclick="loadBlogs()" class="bg-gray-900 hover:bg-gray-800 text-white px-6 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center justify-center gap-2 w-full md:w-auto">
                <i class="fa-solid fa-sliders text-xs"></i> Apply Filters
            </button>
        </div>

        <!-- TABLE CONTAINER WITH HORIZONTAL SCROLLER -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-2">
            <div class="w-full overflow-x-auto block scrollbar-thin">
                <table id="blogDataTable" class="display w-full min-w-[900px]">
                    <thead>
                        <tr>
                            <th class="w-16 text-center">ID</th>
                            <th class="w-20 text-center">Cover</th>
                            <th>Blog Particulars</th>
                            <th>Category</th>
                            <th>Author</th>
                            <th class="text-center">Status</th>
                            <th>Created Date</th>
                            <th class="w-28 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // const baseApiUrl = "https://localhost:44394/api/BlogApi";
        const baseApiUrl = "/api/BlogApi";

        let blogTable;

        $(document).ready(function () {
            loadBlogs();

            $("#searchBox").on("keypress", function (e) {
                if (e.which === 13) loadBlogs();
            });
        });

        function loadBlogs() {
            $.ajax({
                url: `${baseApiUrl}/admin/list`,
                type: "GET",
                data: {
                    search: $("#searchBox").val() || null,
                    status: $("#statusFilter").val() || null,
                    page: 1,
                    pageSize: 100
                },
                success: function (res) {
                    if (blogTable) {
                        blogTable.destroy();
                        $("#blogDataTable tbody").empty();
                    }

                    let rows = res.data.map(item => {
                        // Image conditional parsing logic
                        let imgHtml = '';
                        if (item.image_url && item.image_url.trim().length > 30) {
                            // Check if the data prefix is already attached by the server database output
                            let imgSrc = item.image_url.startsWith('http') || item.image_url.startsWith('data:')
                                ? item.image_url
                                : 'data:image/jpeg;base64,' + item.image_url;

                            imgHtml = `<img src="${imgSrc}" class="w-11 h-11 rounded-lg object-cover border border-gray-100 shadow-sm mx-auto" onerror="this.onerror=null; this.parentNode.innerHTML='<div class=\'w-11 h-11 rounded-lg bg-red-50 text-red-400 border border-red-100 flex flex-col items-center justify-center text-[9px] font-semibold mx-auto\'><i class=\'fa-solid fa-triangle-exclamation text-xs\'></i>Corrupt</div>';" />`;
                        } else {
                            imgHtml = `<div class="w-11 h-11 rounded-lg bg-gray-100 flex flex-col items-center justify-center text-[9px] text-gray-400 font-semibold border border-dashed border-gray-200 mx-auto"><i class="fa-regular fa-image text-xs mb-0.5"></i>No Img</div>`;
                        }

                        let date = item.created_at
                            ? new Date(item.created_at).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' })
                            : "<span class='text-gray-400'>N/A</span>";

                        let statusStr = (item.status || 'DRAFT').toUpperCase();
                        let statusBadge = statusStr === 'PUBLISHED'
                            ? `<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-200"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Published</span>`
                            : `<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-200"><span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>Draft</span>`;

                        return [
                            `<span class="font-mono text-gray-400 text-xs">${item.post_id}</span>`,
                            imgHtml,
                            `<div class="max-w-xs md:max-w-md whitespace-normal"><h3 class="font-semibold text-gray-900 line-clamp-1">${item.title || 'Untitled Post'}</h3><p class="text-xs text-gray-400 font-mono mt-0.5">${item.slug || 'no-slug'}</p></div>`,
                            `<span class="bg-gray-100 text-gray-700 px-2.5 py-1 rounded-md text-xs font-medium border border-gray-200/60">${item.category_name || 'Uncategorized'}</span>`,
                            `<div class="flex items-center gap-2"><div class="w-5 h-5 rounded-full bg-blue-100 text-blue-700 text-[10px] font-bold flex items-center justify-center uppercase">${(item.author_name || 'A').charAt(0)}</div><span class="text-gray-700 font-medium">${item.author_name || 'Admin'}</span></div>`,
                            statusBadge,
                            date,
                            `
                            <div class="flex items-center justify-center gap-1.5">
                                <button onclick="handleAction('view', ${item.post_id})" class="p-1.5 hover:bg-gray-100 rounded-lg text-gray-500 hover:text-blue-600 transition-colors" title="View">
                                    <i class="fa-regular fa-eye text-sm"></i>
                                </button>
                                <button onclick="handleAction('edit', ${item.post_id})" class="p-1.5 hover:bg-gray-100 rounded-lg text-gray-500 hover:text-amber-600 transition-colors" title="Edit">
                                    <i class="fa-regular fa-pen-to-square text-sm"></i>
                                </button>
                                <button onclick="handleAction('delete', ${item.post_id})" class="p-1.5 hover:bg-gray-100 rounded-lg text-gray-500 hover:text-red-600 transition-colors" title="Delete">
                                    <i class="fa-regular fa-trash-can text-sm"></i>
                                </button>
                            </div>
                            `
                        ];
                    });

                    blogTable = $("#blogDataTable").DataTable({
                        data: rows,
                        pageLength: 10,
                        responsive: false, // Turned off responsive extension so the CSS parent overflow scroller safely takes priority
                        ordering: true,
                        order: [[0, "desc"]],
                        columnDefs: [
                            { orderable: false, targets: [1, 7] },
                            { className: "dt-center", targets: [0, 1, 5, 7] }
                        ]
                    });
                },
                error: function () {
                    alert("Failed to load blog components.");
                }
            });
        }

        function handleAction(type, id) {
            if (type === "view") {
                window.open(`/blog/details/${id}`, "_blank");
            }
            if (type === "edit") {
                window.location.href = `/Superadmin/Blog/Edit/${id}`;
            }
            if (type === "create") {
                window.location.href = `/Admin/Blog/Create`;
            }
            if (type === "delete") {
                if (confirm("Are you sure you want to delete this blog post?")) {
                    $.ajax({
                        url: `${baseApiUrl}/admin/delete/${id}`,
                        type: "DELETE",
                        success: function () {
                            alert("Deleted successfully.");
                            loadBlogs();
                        },
                        error: function() {
                            alert("Could not complete delete operation.");
                        }
                    });
                }
            }
        }
    </script>
</body>
</html>